# Copy to .env — this file IS committed; .env is git-ignored.
# Generate secrets with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

POSTGRES_USER=hr
POSTGRES_PASSWORD=hr
POSTGRES_DB=hr_payroll

DATABASE_URL=postgresql+asyncpg://hr:hr@postgres:5432/hr_payroll
JWT_SECRET=CHANGE_ME_generate_with_secrets_token_urlsafe_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=120

# PII field-level encryption (DPDP Act 2023) — see shared/hr_shared/crypto.py
FIELD_ENCRYPTION_KEY=CHANGE_ME_generate_with_Fernet_generate_key

PT_DEFAULT_STATE=Maharashtra
PF_CEILING_ENABLED=true

# ── MinIO object storage ──────────────────────────────────────────────────────
# Root credentials: used ONLY by the minio container and minio-init provisioner.
# Never injected into application service containers.
MINIO_ROOT_USER=CHANGE_ME_minio_root_user
MINIO_ROOT_PASSWORD=CHANGE_ME_generate_with_secrets_token_urlsafe_32

# Service account: least-privilege IAM user created by scripts/init-minio.sh.
# These are the credentials the blobstore-service uses at runtime.
# MINIO_SERVICE_ACCESS_KEY becomes the IAM username (access key ID).
# MINIO_SERVICE_SECRET_KEY must be at least 8 characters.
MINIO_SERVICE_ACCESS_KEY=blobstore-svc
MINIO_SERVICE_SECRET_KEY=CHANGE_ME_generate_with_secrets_token_urlsafe_32

# For seed.py running on the host (talks to the gateway):
GATEWAY_URL=http://localhost:8000
