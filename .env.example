# Copy to .env (optional). docker-compose already sets sensible defaults.
POSTGRES_USER=hr
POSTGRES_PASSWORD=hr
POSTGRES_DB=hr_payroll

DATABASE_URL=postgresql+asyncpg://hr:hr@postgres:5432/hr_payroll
JWT_SECRET=super-secret-shared-key-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=120

PT_DEFAULT_STATE=Maharashtra
PF_CEILING_ENABLED=true

# For seed.py running on the host (talks to the gateway):
GATEWAY_URL=http://localhost:8000
