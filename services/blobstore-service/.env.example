# Environment variables for Blobstore Microservice
# Copy this file to .env and fill in your actual values

# ===== APPLICATION =====
APP_NAME=Blobstore Microservice
APP_VERSION=2.0.0
DEBUG=false
APP_ENV=development

# ===== DATABASE (PostgreSQL) =====
# Platform deployment shares the hr_payroll database (public schema).
DATABASE_URL=postgresql+asyncpg://hr:hr@localhost:5432/hr_payroll

# ===== AUTH / JWT (shared platform secret) =====
# Must match auth-service and every other service.
JWT_SECRET=CHANGE_ME_generate_with_python_-c_"import secrets; print(secrets.token_urlsafe(32))"
JWT_ALGORITHM=HS256

# ===== CORS =====
# JSON list of allowed origins. A wildcard disables credentialed CORS.
CORS_ALLOW_ORIGINS=["http://localhost:5173"]

# ===== MINIO OBJECT STORAGE =====
# Use the service account credentials created by scripts/init-minio.sh.
# Root credentials (MINIO_ROOT_USER / MINIO_ROOT_PASSWORD) must NEVER appear here.
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=blobstore-svc
MINIO_SECRET_KEY=CHANGE_ME_must_match_MINIO_SERVICE_SECRET_KEY_in_root_env
MINIO_SECURE=false

# ===== FILE CONSTRAINTS =====
MAX_FILE_SIZE_BYTES=104857600
PRESIGNED_URL_EXPIRY_SECONDS=3600
PRESIGNED_URL_MAX_EXPIRY_SECONDS=86400

# ===== RETENTION =====
SOFT_DELETE_RETENTION_DAYS=90
ORG_ARCHIVE_RETENTION_YEARS=7

# ===== MINIO RETRY SETTINGS =====
MINIO_MAX_RETRIES=5
MINIO_RETRY_DELAY_SECONDS=2.0

# ===== KAFKA EVENT STREAMING =====
# Enable to consume org-lifecycle events and run the blob event stream.
ENABLE_KAFKA_CONSUMER=false
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_BLOB_EVENTS=blob.events.v1
KAFKA_TOPIC_ORG_EVENTS=org.events.v1
CONSUMER_LAG_THRESHOLD_SECONDS=300

# ===== TRANSACTIONAL OUTBOX =====
OUTBOX_RELAY_INTERVAL_SECONDS=10
OUTBOX_MAX_ATTEMPTS=10
OUTBOX_BATCH_SIZE=100
